# ============================================================
#  Market Intel Dashboard — environment template
#  COPY this file to `.env` and fill in your ROTATED keys.
#  The .env file is git-ignored. NEVER commit real keys.
# ============================================================

# --- Alpaca (paper trading account) ---
# Get keys from https://app.alpaca.markets/paper/dashboard/overview
# IMPORTANT: rotate the keys you exposed earlier before pasting new ones here.
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=

# Paper trading uses paper-api.alpaca.markets.
# Set to "https://api.alpaca.markets" only if you fully understand the risk
# of executing REAL trades. The system disclaimers assume paper.
APCA_BASE_URL=https://paper-api.alpaca.markets

# Data API base — IEX (free tier) by default. "sip" requires a paid plan.
APCA_DATA_FEED=iex

# --- NewsAPI (optional) ---
# Get a key from https://newsapi.org/
NEWS_API_KEY=
